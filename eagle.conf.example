# outproxy-eagle configuration example.
# Copy to eagle.conf and edit. Lines starting with # are comments.
# Without a config file the built-in defaults below are used automatically.

# ---- Listeners (0.0.0.0 = public, 127.0.0.1 = local only) ----
socks  0.0.0.0:1080
http   0.0.0.0:3128
# Web UI: keep it on localhost and put nginx + TLS in front for public access.
web    127.0.0.1:8161

# ---- Parent proxies: name  type(socks5|http|direct)  host:port ----
parent tor    socks5  127.0.0.1:9050
parent i2pd   http    127.0.0.1:4444

# ---- Routing rules: first match wins ----
# route <pattern> <parent-name>     (pattern: *, *.suffix, exact, CIDR)
# deny  <pattern>                    (block; reply refused)
# "direct" is a built-in parent meaning "connect directly via system DNS".
#
# Default behaviour: onion -> tor, i2p -> i2pd, everything else -> direct.
route  *.onion   tor
route  *.i2p     i2pd
route  *         direct

# Examples you can enable:
# deny   *.doubleclick.net
# deny   10.0.0.0/8
# route  *.ygg      tor

# ---- Misc ----
set title        outproxy-eagle
set webdir       web
set logfile      eagle.log
set statsfile    stats.json
set topsize      10
set logmax       10485760
set dumpinterval 30
